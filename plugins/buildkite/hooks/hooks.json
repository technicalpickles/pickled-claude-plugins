{
  "description": "Enforce buildkite tool preferences (bktide over bk CLI)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-bk-preference.sh"
          }
        ]
      }
    ]
  }
}
